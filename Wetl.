<!DOCTYPE html>
<html>
<head>
    <title>File Download</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #f2f2f2;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .box {
            background: white;
            padding: 30px;
            border-radius: 10px;
            text-align: center;
            width: 90%;
            max-width: 400px;
        }

        .btn {
            display: inline-block;
            margin-top: 20px;
            padding: 12px 20px;
            background: black;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .file {
            margin-top: 10px;
            color: gray;
        }
    </style>
</head>

<body>

<div class="box">
    <h2>Your file is ready</h2>
    <p class="file">example-file.zip (25MB)</p>
    <a href="#" class="btn">Download</a>
</div>

</body>
</html>
